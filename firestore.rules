// =========================================================
// FIREBASE FIRESTORE SECURITY RULES - FINAL MERGED VERSION
// =========================================================
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================
    // PUBLIC SIMPLE COLLECTIONS
    // ============================================================
    match /news/{documentId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /tailors/{tailorId} {
      allow read: if true;
      // Allow authenticated tailors to update their own document
      // This is needed for Stripe Connect account linking
      allow write: if request.auth != null && request.auth.uid == tailorId;
    }

    match /waiting_list/{docId} {
      allow read, write: if true; // dev only
    }

    match /campaigns/{id} {
      allow read, write: if true; // test only
    }

    match /tailor_works/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if false; // admin only
    }

    match /collectionProducts/{collectionProducts} {
      allow read: if true;
      allow write: if false; // admin only
    }

    // ============================================
    // ADMINS COLLECTION
    // Admin dashboard user management
    // ============================================
    match /admins/{adminId} {
      // Helper function to check if user is authenticated admin
      function isAdmin() {
        return request.auth != null 
          && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
      }
      
      // Helper function to check if user is Super Admin
      function isSuperAdmin() {
        return request.auth != null 
          && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
      }
      
      // Read permissions:
      // 1. Authenticated users can read their own admin document (needed for login validation)
      // 2. Super Admins can read all admin documents
      allow read: if (request.auth != null && request.auth.uid == adminId)
        || isSuperAdmin();
      
      // Create permissions:
      // Only Super Admins can create new admin documents
      allow create: if isSuperAdmin();
      
      // Update permissions:
      // 1. Super Admins can update any admin document
      // 2. Admins can update their own document (limited fields - cannot change role)
      allow update: if isSuperAdmin()
        || (request.auth != null 
          && request.auth.uid == adminId
          && request.resource.data.role == resource.data.role
          && request.resource.data.uid == resource.data.uid);
      
      // Delete permissions:
      // Only Super Admins can delete admin documents
      allow delete: if isSuperAdmin();
    }

    // ============================================================
    // ANALYTICS COLLECTIONS
    // ============================================================
    
    // Helper function to check if user is Atlas user
    function isAtlasUser() {
      return request.auth != null 
        && exists(/databases/$(database)/documents/atlasUsers/$(request.auth.uid));
    }
    
    // Helper function to check if user is back office user with analytics permission
    function isBackOfficeAnalyticsUser() {
      return request.auth != null 
        && exists(/databases/$(database)/documents/backoffice_users/$(request.auth.uid));
    }
    
    // Helper function to check if user is authenticated admin
    function isAnalyticsAdmin() {
      return request.auth != null 
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    
    // Helper function to check if user has analytics access
    function hasAnalyticsAccess() {
      return isAnalyticsAdmin() || isAtlasUser() || isBackOfficeAnalyticsUser();
    }

    // Product Analytics Collections
    match /product_analytics/{productId} {
      allow read: if hasAnalyticsAccess();
      allow write: if false; // Only Cloud Functions should write
    }

    match /product_views/{viewId} {
      allow read: if hasAnalyticsAccess();
      allow create: if true; // Allow anonymous tracking
      allow update, delete: if false;
    }

    // Search Analytics Collections
    match /search_analytics/{searchId} {
      allow read: if hasAnalyticsAccess();
      allow write: if false; // Only Cloud Functions should write
    }

    match /searches/{searchId} {
      allow read: if hasAnalyticsAccess();
      allow create: if true; // Allow anonymous tracking
      allow update, delete: if false;
    }

    // Session Analytics Collections
    match /user_session_analytics/{userId} {
      allow read: if hasAnalyticsAccess();
      allow write: if false; // Only Cloud Functions should write
    }

    match /user_sessions/{sessionId} {
      allow read: if hasAnalyticsAccess();
      allow create: if true; // Allow anonymous tracking
      allow update, delete: if false;
    }

    // Cart Analytics Collections
    match /cart_analytics/{cartId} {
      allow read: if hasAnalyticsAccess();
      allow write: if false; // Only Cloud Functions should write
    }

    // Install Analytics Collections
    match /install_analytics/{installId} {
      allow read: if hasAnalyticsAccess();
      allow create: if true; // Allow anonymous tracking
      allow update, delete: if false;
    }

    // ============================================================
    // USERS
    // ============================================================
    match /users/{userId} {
      // Helper function to check if user is authorized marketing user for VVIP operations
      function isVvipAuthorizedUser() {
        return request.auth != null &&
          exists(/databases/$(database)/documents/marketing_users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/marketing_users/$(request.auth.uid)).data.isActive == true &&
          get(/databases/$(database)/documents/marketing_users/$(request.auth.uid)).data.role in ['super_admin', 'bdm', 'team_lead'];
      }

      // Helper function to check if VVIP fields are being modified
      function isVvipFieldUpdate() {
        return request.resource.data.diff(resource.data).affectedKeys().hasAny(['isVvip', 'vvip_created_by', 'vvip_created_at']);
      }

      // Allow analytics users to read user data for location analytics
      allow read: if (request.auth != null && request.auth.uid == userId) || hasAnalyticsAccess();
      
      // Write permissions:
      // 1. Users can update their own document (except VVIP fields)
      // 2. Authorized marketing users can update VVIP fields only
      allow write: if (request.auth != null && request.auth.uid == userId && !isVvipFieldUpdate()) ||
                     (isVvipAuthorizedUser() && isVvipFieldUpdate());
      
      // Subcollection: /users/{userId}/videos/{videoFile}
      match /videos/{videoFile} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Standalone legacy path: /{userId}/videos/{videoFile}
    // (kept for backward compatibility)
    match /{userId}/videos/{videoFile} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Public-facing user profiles
    match /users_local/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ============================================================
    // TAILORS COLLECTIONS
    // ============================================================
    match /tailors_local/{tailorId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == tailorId;
    }

    match /tailor_works_local/{workId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null &&
        request.auth.uid == resource.data.tailorId;
    }

    // ============================================================
    // FAVORITES
    // ============================================================
    match /favorites/{favoriteId} {
      allow read: if request.auth != null &&
        request.auth.uid == resource.data.userId;
      allow write: if request.auth != null &&
        request.auth.uid == request.resource.data.userId;
    }

    // ============================================================
    // ADS
    // ============================================================
    match /ads_local/{adId} {
      allow read: if true;
      allow create: if request.auth != null;
      // User can update/delete their own ad
      allow update, delete: if request.auth != null &&
        (resource.data.userId == request.auth.uid ||
         request.resource.data.userId == request.auth.uid);
    }

    // ============================================================
    // WISHLIST ITEMS
    // ============================================================
    match /users_wishlist_items/{userId}/user_wishlist_items/{itemId} {
      // Allow users to read/write their own wishlist items
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Allow vendors to read wishlist items for their products (for analytics)
      // This enables vendors to see how many users have wishlisted their products
      allow read: if request.auth != null && 
                     resource.data.tailor_id == request.auth.uid;
    }

    // ============================================================
    // ANALYTICS + TRACKING
    // ============================================================
    match /app_installs/{installId} {
      allow create: if true; // anonymous allowed
      allow read, update, delete: if request.auth != null;
    }

    match /vendor_visits/{visitId} {
      allow create: if true; // anonymous allowed
      allow read, update, delete: if request.auth != null;
    }

    match /vendor_analytics/{vendorId} {
      allow read: if true;
      allow write: if true; // app always allowed to update
    }

    // ============================================================
    // VENDOR PRE-REGISTRATION
    // ============================================================
    match /vendor_pre_registrations/{preRegId} {
      allow create, read: if true;
      allow update: if request.auth != null &&
        request.auth.token.role == 'admin';
      allow delete: if false;
    }

    // ============================================================
    // PROMOTIONAL EVENTS
    // ============================================================
    match /promotionalEvents/{eventId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ============================================================
    // ATLAS USERS (Admin system)
    // ============================================================
    match /atlasUsers/{userId} {
      function isAtlasUser() {
        return request.auth != null &&
          exists(/databases/$(database)/documents/atlasUsers/$(request.auth.uid));
      }

      function isSuperAdmin() {
        return request.auth != null &&
          request.auth.uid == userId &&
          resource.data.isAtlasUser == true &&
          resource.data.role == "superadmin";
      }

      function hasValidInvitation() {
        return resource.data.invitationToken != null &&
          resource.data.invitationExpiry != null &&
          resource.data.invitationExpiry > request.time;
      }

      // Allow users to read their own document (fixes circular dependency)
      // Allow other Atlas users to read Atlas user documents  
      // Allow unauthenticated users with valid invitations to read
      allow read: if (request.auth != null && request.auth.uid == userId)
        || (request.auth != null && 
            exists(/databases/$(database)/documents/atlasUsers/$(request.auth.uid)))
        || (request.auth == null && hasValidInvitation());

      allow create: if (request.auth != null &&
          exists(/databases/$(database)/documents/atlasUsers/$(request.auth.uid)))
        || (request.auth != null &&
          request.auth.uid == userId &&
          request.resource.data.uid == request.auth.uid &&
          request.resource.data.isAtlasUser == true &&
          request.resource.data.role == "superadmin");

      allow update: if (request.auth != null &&
          exists(/databases/$(database)/documents/atlasUsers/$(request.auth.uid)))
        || (request.auth != null &&
          request.auth.uid == userId &&
          request.resource.data.email == resource.data.email)
        || (request.auth == null && hasValidInvitation());

      allow delete: if false;
    }
    // ============================================================
    // COLLECTIONS USERS (CMS Admin system)
    // ============================================================
    match /collectionsUsers/{userId} {
      function isCollectionsUser() {
        return request.auth != null &&
          exists(/databases/$(database)/documents/collectionsUsers/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/collectionsUsers/$(request.auth.uid)).data.isCollectionsUser == true;
      }

      function isCollectionsSuperAdmin() {
        return isCollectionsUser() &&
          get(/databases/$(database)/documents/collectionsUsers/$(request.auth.uid)).data.role == "superadmin";
      }

      function hasValidInvitation() {
        return resource.data.invitationToken != null &&
          resource.data.invitationExpiry != null &&
          resource.data.invitationExpiry > request.time;
      }

      function hasRequiredFields() {
        return request.resource.data.uid is string &&
          request.resource.data.email is string &&
          request.resource.data.fullName is string &&
          request.resource.data.role in ["superadmin", "editor", "viewer"] &&
          request.resource.data.isCollectionsUser is bool &&
          request.resource.data.createdAt is timestamp &&
          request.resource.data.updatedAt is timestamp;
      }

      allow read: if (request.auth != null && request.auth.uid == userId)
        || isCollectionsUser()
        || (request.auth == null && hasValidInvitation());

      allow create: if (isCollectionsSuperAdmin() && hasRequiredFields())
        || (request.auth != null &&
          request.auth.uid == userId &&
          hasRequiredFields());

      allow update: if isCollectionsSuperAdmin()
        || (request.auth != null &&
          request.auth.uid == userId)
        || (request.auth == null && hasValidInvitation());

      allow delete: if false;
    }

    // ============================================================
    // PRODUCT COLLECTIONS (CMS)
    // ============================================================
    match /product_collections/{collectionId} {
      function isCollectionsUser() {
        return request.auth != null &&
          exists(/databases/$(database)/documents/collectionsUsers/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/collectionsUsers/$(request.auth.uid)).data.isCollectionsUser == true;
      }

      function canEditCollections() {
        return isCollectionsUser() &&
          (get(/databases/$(database)/documents/collectionsUsers/$(request.auth.uid)).data.role == "superadmin" ||
           get(/databases/$(database)/documents/collectionsUsers/$(request.auth.uid)).data.role == "editor");
      }

      allow read: if true;
      allow create, update, delete: if canEditCollections();
    }

    // ============================================
    // MARKETING TEAMS COLLECTION
    // Marketing dashboard team management
    // ============================================
    match /marketing_teams/{teamId} {
      // Helper function to check if user is authenticated marketing user
      function isMarketingUser() {
        return request.auth != null &&
          exists(/databases/$(database)/documents/marketing_users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/marketing_users/$(request.auth.uid)).data.isActive == true;
      }
      
      // Helper function to check if user is Super Admin
      function isSuperAdmin() {
        return isMarketingUser() &&
          get(/databases/$(database)/documents/marketing_users/$(request.auth.uid)).data.role == "super_admin";
      }
      
      // Helper function to check if user is Team Lead
      function isTeamLead() {
        return isMarketingUser() &&
          get(/databases/$(database)/documents/marketing_users/$(request.auth.uid)).data.role == "team_lead";
      }
      
      // Helper function to check if user is BDM
      function isBDM() {
        return isMarketingUser() &&
          get(/databases/$(database)/documents/marketing_users/$(request.auth.uid)).data.role == "bdm" &&
          get(/databases/$(database)/documents/marketing_users/$(request.auth.uid)).data.isActive == true;
      }
      
      // Helper function to check if user belongs to this team
      function isTeamMember() {
        return isMarketingUser() &&
          (request.auth.uid == resource.data.leadUserId ||
           resource.data.memberUserIds.hasAny([request.auth.uid]));
      }
      
      // Read permissions:
      // 1. Super Admins can read all teams
      // 2. Team Leads can read all teams
      // 3. BDMs can read all teams
      // 4. Team members can read their own team
      allow read: if isSuperAdmin() || isTeamLead() || isBDM() || isTeamMember();
      
      // Create permissions:
      // Only Super Admins can create new teams
      allow create: if isSuperAdmin();
      
      // Update permissions:
      // 1. Super Admins can update any team
      // 2. Team Leads can update their own team
      allow update: if isSuperAdmin() || (isTeamLead() && request.auth.uid == resource.data.leadUserId);
      
      // Delete permissions:
      // Only Super Admins can delete teams (soft delete)
      allow delete: if isSuperAdmin();
    }

    // ============================================
    // VENDOR ASSIGNMENTS COLLECTION
    // Marketing dashboard vendor assignment management
    // ============================================
    match /vendor_assignments/{assignmentId} {
      // Helper function to check if user is authenticated marketing user
      function isMarketingUser() {
        return request.auth != null &&
          exists(/databases/$(database)/documents/marketing_users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/marketing_users/$(request.auth.uid)).data.isActive == true;
      }

      // Helper function to check if user is Super Admin
      function isSuperAdmin() {
        return isMarketingUser() &&
          get(/databases/$(database)/documents/marketing_users/$(request.auth.uid)).data.role == "super_admin";
      }

      // Helper function to check if user is Team Lead
      function isTeamLead() {
        return isMarketingUser() &&
          get(/databases/$(database)/documents/marketing_users/$(request.auth.uid)).data.role == "team_lead";
      }

      // Helper function to check if user is BDM
      function isBDM() {
        return isMarketingUser() &&
          get(/databases/$(database)/documents/marketing_users/$(request.auth.uid)).data.role == "bdm" &&
          get(/databases/$(database)/documents/marketing_users/$(request.auth.uid)).data.isActive == true;
      }

      // Helper function to check if user owns this assignment
      function isAssignmentOwner() {
        return request.auth != null && request.auth.uid == resource.data.assignedToUserId;
      }

      // Helper function to check if user assigned this vendor
      function isAssignmentCreator() {
        return request.auth != null && request.auth.uid == resource.data.assignedByUserId;
      }

      // Helper function to check if user is in the same team as the assignment owner
      function isSameTeam() {
        return isMarketingUser() && 
          resource.data.teamId != null &&
          get(/databases/$(database)/documents/marketing_users/$(request.auth.uid)).data.teamId == resource.data.teamId;
      }

      // Read permissions:
      // 1. Super Admins can read all assignments
      // 2. BDMs can read all assignments
      // 3. Team Leads can read assignments in their team
      // 4. Users can read their own assignments
      // 5. Team members can read assignments in their team
      allow read: if isSuperAdmin() || 
                 isBDM() ||
                 (isTeamLead() && isSameTeam()) || 
                 isAssignmentOwner() || 
                 isSameTeam();

      // Create permissions:
      // 1. Super Admins can create any assignment
      // 2. BDMs can create any assignment
      // 3. Team Leads can create assignments for their team
      allow create: if isSuperAdmin() || isBDM() || isTeamLead();
      
      // Update permissions:
      // 1. Super Admins can update assignments
      // 2. BDMs can update assignments
      allow update: if isSuperAdmin() || isBDM();
      
      // Delete permissions:
      // 1. Super Admins can delete assignments
      // 2. BDMs can delete assignments
      allow delete: if isSuperAdmin() || isBDM();
    }

    // ============================================
    // MARKETING USERS COLLECTION
    // Marketing dashboard user management
    // ============================================
    match /marketing_users/{userId} {
      // Helper function to check if user is authenticated marketing user
      function isMarketingUser() {
        return request.auth != null &&
          exists(/databases/$(database)/documents/marketing_users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/marketing_users/$(request.auth.uid)).data.isActive == true;
      }

      // Helper function to check if user is Super Admin
      function isSuperAdmin() {
        return isMarketingUser() &&
          get(/databases/$(database)/documents/marketing_users/$(request.auth.uid)).data.role == "super_admin";
      }

      // Helper function to check if user is Team Lead
      function isTeamLead() {
        return isMarketingUser() &&
          get(/databases/$(database)/documents/marketing_users/$(request.auth.uid)).data.role == "team_lead";
      }

      // Helper function to check if user is BDM
      function isBDM() {
        return isMarketingUser() &&
          get(/databases/$(database)/documents/marketing_users/$(request.auth.uid)).data.role == "bdm" &&
          get(/databases/$(database)/documents/marketing_users/$(request.auth.uid)).data.isActive == true;
      }

      // Read permissions:
      // 1. Authenticated users can read their own document
      // 2. Super Admins can read all users
      // 3. BDMs can read all users
      // 4. Team Leads can read users in their team
      allow read: if (request.auth != null && request.auth.uid == userId)
        || isSuperAdmin()
        || isBDM()
        || (isTeamLead() && resource.data.teamId == get(/databases/$(database)/documents/marketing_users/$(request.auth.uid)).data.teamId);

      // Create permissions:
      // Only Super Admins can create new user documents
      allow create: if isSuperAdmin();
      
      // Update permissions:
      // 1. Super Admins can update any user
      // 2. BDMs can update any user
      // 3. Users can update their own limited fields (not role or isActive)
      allow update: if isSuperAdmin() || isBDM() ||
        (request.auth != null &&
          request.auth.uid == userId &&
          request.resource.data.role == resource.data.role &&
          request.resource.data.isActive == resource.data.isActive &&
          request.resource.data.email == resource.data.email);
      
      // Delete permissions:
      // No direct deletion allowed (use deactivation instead)
      allow delete: if false;
    }

    // ============================================
    // MARKETING INVITATIONS COLLECTION
    // Marketing dashboard invitation system
    // ============================================
    match /marketing_invitations/{inviteId} {
      // Helper function to check if user is Super Admin
      function isSuperAdmin() {
        return request.auth != null &&
          exists(/databases/$(database)/documents/marketing_users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/marketing_users/$(request.auth.uid)).data.role == "super_admin" &&
          get(/databases/$(database)/documents/marketing_users/$(request.auth.uid)).data.isActive == true;
      }

      // Read permissions:
      // 1. Super Admins can read all invitations
      // 2. Anyone can read their own invitation by email (for validation)
      allow read: if isSuperAdmin()
        || (request.auth != null && resource.data.email == request.auth.token.email);

      // Create permissions:
      // Only Super Admins can create invitations
      allow create: if isSuperAdmin();

      // Update permissions:
      // Only Super Admins can update invitations
      allow update: if isSuperAdmin();

      // Delete permissions:
      // Only Super Admins can delete invitations
      allow delete: if isSuperAdmin();
    }

    // ============================================
    // MARKETING ACTIVITY LOGS COLLECTION
    // Marketing dashboard activity logging
    // ============================================
    match /marketing_activity_logs/{logId} {
      // Helper function to check if user is Super Admin
      function isSuperAdmin() {
        return request.auth != null &&
          exists(/databases/$(database)/documents/marketing_users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/marketing_users/$(request.auth.uid)).data.role == "super_admin" &&
          get(/databases/$(database)/documents/marketing_users/$(request.auth.uid)).data.isActive == true;
      }
      
      // Helper function to check if user is BDM
      function isBDM() {
        return request.auth != null &&
          exists(/databases/$(database)/documents/marketing_users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/marketing_users/$(request.auth.uid)).data.role == "bdm" &&
          get(/databases/$(database)/documents/marketing_users/$(request.auth.uid)).data.isActive == true;
      }
      
      // Read permissions:
      // 1. Super Admins can read activity logs
      // 2. BDMs can read activity logs
      allow read: if isSuperAdmin() || isBDM();
      
      // Create permissions:
      // Any authenticated marketing user can create logs
      allow create: if request.auth != null &&
        exists(/databases/$(database)/documents/marketing_users/$(request.auth.uid));
      
      // Update/Delete permissions:
      // No updates or deletions allowed (immutable audit trail)
      allow update, delete: if false;
    }
    
    // ============================================
    // MARKETING INTERACTIONS COLLECTION
    // Marketing dashboard user interactions tracking
    // ============================================
    match /marketing_interactions/{interactionId} {
      // Helper function to check if user is authenticated marketing user
      function isMarketingUser() {
        return request.auth != null &&
          exists(/databases/$(database)/documents/marketing_users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/marketing_users/$(request.auth.uid)).data.isActive == true;
      }
      
      // Helper function to check if user is Super Admin
      function isSuperAdmin() {
        return isMarketingUser() &&
          get(/databases/$(database)/documents/marketing_users/$(request.auth.uid)).data.role == "super_admin";
      }
      
      // Read permissions:
      // 1. Super Admins can read all interactions
      // 2. BDMs can read all interactions
      // 3. Users can read their own interactions
      allow read: if isSuperAdmin() || 
                   isBDM() ||
                   (request.auth != null && request.auth.uid == resource.data.userId);
      
      // Create permissions:
      // Any authenticated marketing user can create interactions
      allow create: if isMarketingUser();
      
      // Update permissions:
      // 1. Super Admins can update interactions
      // 2. BDMs can update interactions
      allow update: if isSuperAdmin() || isBDM();
      
      // Delete permissions:
      // 1. Super Admins can delete interactions
      // 2. BDMs can delete interactions
      allow delete: if isSuperAdmin() || isBDM();
    }
    
    // ============================================
    // MARKETING TASKS COLLECTION
    // Marketing dashboard task management
    // ============================================
    match /marketing_tasks/{taskId} {
      // Helper function to check if user is authenticated marketing user
      function isMarketingUser() {
        return request.auth != null &&
          exists(/databases/$(database)/documents/marketing_users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/marketing_users/$(request.auth.uid)).data.isActive == true;
      }
      
      // Helper function to check if user is Super Admin
      function isSuperAdmin() {
        return isMarketingUser() &&
          get(/databases/$(database)/documents/marketing_users/$(request.auth.uid)).data.role == "super_admin";
      }
      
      // Helper function to check if user is Team Lead
      function isTeamLead() {
        return isMarketingUser() &&
          get(/databases/$(database)/documents/marketing_users/$(request.auth.uid)).data.role == "team_lead";
      }
      
      // Helper function to check if user is BDM
      function isBDM() {
        return isMarketingUser() &&
          get(/databases/$(database)/documents/marketing_users/$(request.auth.uid)).data.role == "bdm" &&
          get(/databases/$(database)/documents/marketing_users/$(request.auth.uid)).data.isActive == true;
      }
      
      // Helper function to check if user owns this task
      function isTaskOwner() {
        return request.auth != null && 
          (request.auth.uid == resource.data.assignedToUserId ||
           request.auth.uid == resource.data.createdByUserId);
      }
      
      // Helper function to check if user is in the same team as the task owner
      function isSameTeam() {
        return isMarketingUser() && 
          resource.data.teamId != null &&
          get(/databases/$(database)/documents/marketing_users/$(request.auth.uid)).data.teamId == resource.data.teamId;
      }
      
      // Read permissions:
      // 1. Super Admins can read all tasks
      // 2. BDMs can read all tasks
      // 3. Team Leads can read tasks in their team
      // 4. Users can read their own tasks
      // 5. Team members can read tasks in their team
      allow read: if isSuperAdmin() || 
                 isBDM() ||
                 (isTeamLead() && isSameTeam()) || 
                 isTaskOwner() || 
                 isSameTeam();
      
      // Create permissions:
      // 1. Super Admins can create any task
      // 2. BDMs can create any task
      // 3. Team Leads can create tasks for their team
      allow create: if isSuperAdmin() || isBDM() || isTeamLead();
      
      // Update permissions:
      // 1. Super Admins can update any task
      // 2. BDMs can update any task
      // 3. Task owners can update their tasks
      // 4. Team Leads can update tasks in their team
      allow update: if isSuperAdmin() || isBDM() || isTaskOwner() || (isTeamLead() && isSameTeam());
      
      // Delete permissions:
      // 1. Super Admins can delete tasks
      // 2. BDMs can delete tasks
      allow delete: if isSuperAdmin() || isBDM();
    }
    
    // ============================================
    // MARKETING SECTION COLLECTION
    // Marketing dashboard section management
    // ============================================
    match /marketing_sections/{sectionId} {
      // Helper function to check if user is authenticated marketing user
      function isMarketingUser() {
        return request.auth != null &&
          exists(/databases/$(database)/documents/marketing_users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/marketing_users/$(request.auth.uid)).data.isActive == true;
      }
      
      // Helper function to check if user is Super Admin
      function isSuperAdmin() {
        return isMarketingUser() &&
          get(/databases/$(database)/documents/marketing_users/$(request.auth.uid)).data.role == "super_admin";
      }
      
      // Helper function to check if user is Team Lead
      function isTeamLead() {
        return isMarketingUser() &&
          get(/databases/$(database)/documents/marketing_users/$(request.auth.uid)).data.role == "team_lead";
      }
      
      // Helper function to check if user is BDM
      function isBDM() {
        return isMarketingUser() &&
          get(/databases/$(database)/documents/marketing_users/$(request.auth.uid)).data.role == "bdm" &&
          get(/databases/$(database)/documents/marketing_users/$(request.auth.uid)).data.isActive == true;
      }
      
      // Helper function to check if user is in the same team as the section
      function isSameTeam() {
        return isMarketingUser() && 
          resource.data.teamId != null &&
          get(/databases/$(database)/documents/marketing_users/$(request.auth.uid)).data.teamId == resource.data.teamId;
      }
      
      // Helper function to check if user is a member of the section
      function isSectionMember() {
        return isMarketingUser() &&
          resource.data.memberIds.hasAny([request.auth.uid]);
      }
      
      // Read permissions:
      // 1. Super Admins can read all sections
      // 2. BDMs can read all sections
      // 3. Team Leads can read sections in their team
      // 4. Section members can read their sections
      allow read: if isSuperAdmin() || isBDM() || (isTeamLead() && isSameTeam()) || isSectionMember();
      
      // Create permissions:
      // 1. Super Admins can create sections for any team
      // 2. BDMs can create sections
      // 3. Team Leads can create sections for their team
      allow create: if isSuperAdmin() || isBDM() || (isTeamLead() && isSameTeam());
      
      // Update permissions:
      // 1. Super Admins can update any section
      // 2. BDMs can update any section
      // 3. Team Leads can update sections in their team
      allow update: if isSuperAdmin() || isBDM() || (isTeamLead() && isSameTeam());
      
      // Delete permissions:
      // 1. Super Admins can delete any section
      // 2. BDMs can delete any section
      // 3. Team Leads can delete sections in their team
      allow delete: if isSuperAdmin() || isBDM() || (isTeamLead() && isSameTeam());
    }
    
    // ============================================
    // MARKETING NOTIFICATIONS COLLECTION
    // Marketing dashboard notifications
    // ============================================
    match /marketing_notifications/{notificationId} {
      // Helper function to check if user is authenticated marketing user
      function isMarketingUser() {
        return request.auth != null &&
          exists(/databases/$(database)/documents/marketing_users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/marketing_users/$(request.auth.uid)).data.isActive == true;
      }
      
      // Helper function to check if user is Super Admin
      function isSuperAdmin() {
        return isMarketingUser() &&
          get(/databases/$(database)/documents/marketing_users/$(request.auth.uid)).data.role == "super_admin";
      }
      
      // Helper function to check if user is BDM
      function isBDM() {
        return isMarketingUser() &&
          get(/databases/$(database)/documents/marketing_users/$(request.auth.uid)).data.role == "bdm" &&
          get(/databases/$(database)/documents/marketing_users/$(request.auth.uid)).data.isActive == true;
      }
      
      // Read permissions:
      // 1. Super Admins can read all notifications
      // 2. BDMs can read all notifications
      // 3. Users can read their own notifications
      allow read: if isSuperAdmin() || 
                   isBDM() ||
                   (request.auth != null && request.auth.uid == resource.data.userId);
      
      // Create permissions:
      // 1. Super Admins can create any notification
      // 2. BDMs can create any notification
      // 3. System can create notifications for users
      allow create: if isSuperAdmin() || isBDM() || request.auth != null;
      
      // Update permissions:
      // 1. Super Admins can update any notification
      // 2. BDMs can update any notification
      // 3. Users can update their own notification status
      allow update: if isSuperAdmin() || 
                     isBDM() ||
                     (request.auth != null && request.auth.uid == resource.data.userId);
      
      // Delete permissions:
      // 1. Super Admins can delete any notification
      // 2. BDMs can delete any notification
      // 3. Users can delete their own notifications
      allow delete: if isSuperAdmin() || 
                     isBDM() ||
                     (request.auth != null && request.auth.uid == resource.data.userId);
    }
    
    // ============================================
    // VVIP AUDIT LOGS COLLECTION
    // VVIP Shopper Program audit trail
    // ============================================
    match /vvip_audit_logs/{logId} {
      // Helper function to check if user is authorized marketing user
      function isVvipAuthorizedUser() {
        return request.auth != null &&
          exists(/databases/$(database)/documents/marketing_users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/marketing_users/$(request.auth.uid)).data.isActive == true;
      }

      // Helper function to check if user is Super Admin or BDM
      function isVvipAdminUser() {
        return isVvipAuthorizedUser() &&
          get(/databases/$(database)/documents/marketing_users/$(request.auth.uid)).data.role in ['super_admin', 'bdm'];
      }

      // Read permissions:
      // 1. Super Admins and BDMs can read all audit logs
      // 2. Team Leads and Team Members can read audit logs for users they have access to
      allow read: if isVvipAdminUser() || 
                    (isVvipAuthorizedUser() && 
                     (resource.data.performed_by == request.auth.uid || 
                      resource.data.affected_user == request.auth.uid));

      // Create permissions:
      // Any authorized marketing user can create audit logs (system operation)
      allow create: if isVvipAuthorizedUser() &&
        request.resource.data.performed_by == request.auth.uid &&
        request.resource.data.timestamp != null &&
        request.resource.data.action_type in ['vvip_created', 'vvip_revoked', 'payment_approved', 'payment_rejected'];

      // Update/Delete permissions:
      // Audit logs are immutable (no updates or deletions allowed)
      allow update, delete: if false;
    }
    
    // ============================================
    // VVIP SHOPPERS COLLECTION
    // VVIP Shopper Program main collection
    // ============================================
    match /vvip_shoppers/{vvipId} {
      // Helper function to check if user is authorized marketing user
      function isVvipAuthorizedUser() {
        return request.auth != null &&
          exists(/databases/$(database)/documents/marketing_users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/marketing_users/$(request.auth.uid)).data.isActive == true;
      }

      // Helper function to check if user is Super Admin or BDM
      function isVvipAdminUser() {
        return isVvipAuthorizedUser() &&
          get(/databases/$(database)/documents/marketing_users/$(request.auth.uid)).data.role in ['super_admin', 'bdm'];
      }

      // Helper function to check if user is Team Lead
      function isVvipTeamLead() {
        return isVvipAuthorizedUser() &&
          get(/databases/$(database)/documents/marketing_users/$(request.auth.uid)).data.role == 'team_lead';
      }

      // Helper function to check if user can manage VVIP shoppers
      function canManageVvipShoppers() {
        return isVvipAdminUser() || isVvipTeamLead();
      }

      // Helper function to check if user is the creator of this VVIP record
      function isVvipCreator() {
        return isVvipAuthorizedUser() &&
          resource.data.created_by == request.auth.uid;
      }

      // Read permissions:
      // 1. Super Admins and BDMs can read all VVIP shoppers
      // 2. Team Leads can read all VVIP shoppers
      // 3. Team Members can read VVIP shoppers they created
      allow read: if isVvipAdminUser() || 
                    isVvipTeamLead() ||
                    (isVvipAuthorizedUser() && isVvipCreator());

      // Create permissions:
      // 1. Super Admins, BDMs, and Team Leads can create VVIP shoppers
      // 2. Must set created_by to their own user ID
      allow create: if canManageVvipShoppers() &&
        request.resource.data.created_by == request.auth.uid &&
        request.resource.data.created_at != null &&
        request.resource.data.status == 'active' &&
        request.resource.data.userId != null;

      // Update permissions:
      // 1. Super Admins and BDMs can update any VVIP shopper
      // 2. Team Leads can update VVIP shoppers (status changes only)
      // 3. Cannot change userId or created_by after creation
      allow update: if (isVvipAdminUser() || 
                       (isVvipTeamLead() && 
                        request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'updated_at', 'updated_by']))) &&
        request.resource.data.userId == resource.data.userId &&
        request.resource.data.created_by == resource.data.created_by;

      // Delete permissions:
      // Only Super Admins can delete VVIP shoppers (soft delete preferred via status update)
      allow delete: if isVvipAuthorizedUser() &&
        get(/databases/$(database)/documents/marketing_users/$(request.auth.uid)).data.role == 'super_admin';
    }
    
    // ============================================
    // REFERRAL PROGRAM COLLECTIONS
    // Referral system for user referrals and rewards
    // ============================================

    // Referral Users Collection
    match /referralUsers/{userId} {
      // Helper function to check if user is admin
      function isReferralAdmin() {
        return request.auth != null &&
          exists(/databases/$(database)/documents/referralUsers/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/referralUsers/$(request.auth.uid)).data.isAdmin == true;
      }

      // Helper function to check if user has analytics access (Atlas users)
      function hasAnalyticsAccess() {
        return request.auth != null &&
          (exists(/databases/$(database)/documents/atlasUsers/$(request.auth.uid)) ||
           exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
           exists(/databases/$(database)/documents/backoffice_users/$(request.auth.uid)));
      }

      // Read permissions:
      // 1. Authenticated users can read their own document
      // 2. Admins can read all referral users
      // 3. Atlas users can read all referral users for analytics
      allow read: if request.auth != null &&
        (request.auth.uid == userId || isReferralAdmin() || hasAnalyticsAccess());

      // Create permissions:
      // Users can create their own referral account
      allow create: if request.auth != null &&
        request.auth.uid == userId &&
        request.resource.data.userId == request.auth.uid;

      // Update permissions:
      // 1. Users can update their own document
      // 2. Admins can update any document
      allow update: if request.auth != null &&
        (request.auth.uid == userId || isReferralAdmin());

      // Delete permissions:
      // Only admins can delete (soft delete preferred)
      allow delete: if isReferralAdmin();
    }

    // Referrals Collection
    match /referrals/{referralId} {
      // Helper function to check if user is admin
      function isReferralAdmin() {
        return request.auth != null &&
          exists(/databases/$(database)/documents/referralUsers/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/referralUsers/$(request.auth.uid)).data.isAdmin == true;
      }

      // Helper function to check if user has analytics access (Atlas users)
      function hasAnalyticsAccess() {
        return request.auth != null &&
          (exists(/databases/$(database)/documents/atlasUsers/$(request.auth.uid)) ||
           exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
           exists(/databases/$(database)/documents/backoffice_users/$(request.auth.uid)));
      }

      // Read permissions:
      // 1. Referrers can read their own referrals
      // 2. Referees can read referrals where they are the referee
      // 3. Admins can read all referrals
      // 4. Atlas users can read all referrals for analytics
      allow read: if request.auth != null &&
        (resource.data.referrerId == request.auth.uid ||
         resource.data.refereeId == request.auth.uid ||
         isReferralAdmin() ||
         hasAnalyticsAccess());

      // Create permissions:
      // System creates referrals (authenticated users)
      allow create: if request.auth != null;

      // Update permissions:
      // 1. Referrers can update their referrals
      // 2. Admins can update any referral
      allow update: if request.auth != null &&
        (resource.data.referrerId == request.auth.uid || isReferralAdmin());

      // Delete permissions:
      // Only admins can delete
      allow delete: if isReferralAdmin();
    }

    // Referral Transactions Collection
    match /referralTransactions/{transactionId} {
      // Helper function to check if user is admin
      function isReferralAdmin() {
        return request.auth != null &&
          exists(/databases/$(database)/documents/referralUsers/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/referralUsers/$(request.auth.uid)).data.isAdmin == true;
      }

      // Helper function to check if user has analytics access (Atlas users)
      function hasAnalyticsAccess() {
        return request.auth != null &&
          (exists(/databases/$(database)/documents/atlasUsers/$(request.auth.uid)) ||
           exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
           exists(/databases/$(database)/documents/backoffice_users/$(request.auth.uid)));
      }

      // Read permissions:
      // 1. Referrers can read their own transactions
      // 2. Admins can read all transactions
      // 3. Atlas users can read all transactions for analytics
      allow read: if request.auth != null &&
        (resource.data.referrerId == request.auth.uid || isReferralAdmin() || hasAnalyticsAccess());

      // Create permissions:
      // System creates transactions (authenticated users)
      allow create: if request.auth != null;

      // Update/Delete permissions:
      // Transactions are immutable (only admins can modify for corrections)
      allow update, delete: if isReferralAdmin();
    }

    // Referral Purchases Collection
    match /referralPurchases/{purchaseId} {
      // Helper function to check if user is admin
      function isReferralAdmin() {
        return request.auth != null &&
          exists(/databases/$(database)/documents/referralUsers/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/referralUsers/$(request.auth.uid)).data.isAdmin == true;
      }

      // Read permissions:
      // 1. Referrers can read purchases from their referrals
      // 2. Referees can read their own purchases
      // 3. Admins can read all purchases
      allow read: if request.auth != null &&
        (resource.data.referrerId == request.auth.uid ||
         resource.data.refereeId == request.auth.uid ||
         isReferralAdmin());

      // Create permissions:
      // System creates purchase records (authenticated users)
      allow create: if request.auth != null;

      // Update permissions:
      // Only admins can update (for status changes, refunds)
      allow update: if isReferralAdmin();

      // Delete permissions:
      // Only admins can delete
      allow delete: if isReferralAdmin();
    }

    // Referral Analytics Collection
    match /referralAnalytics/{analyticsId} {
      // Helper function to check if user is admin
      function isReferralAdmin() {
        return request.auth != null &&
          exists(/databases/$(database)/documents/referralUsers/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/referralUsers/$(request.auth.uid)).data.isAdmin == true;
      }

      // Read permissions:
      // Only admins can read analytics
      allow read: if isReferralAdmin();

      // Write permissions:
      // Only admins and system can write analytics
      allow create, update: if isReferralAdmin();

      // Delete permissions:
      // Only admins can delete
      allow delete: if isReferralAdmin();
    }

    // Referral Events Collection
    match /referralEvents/{eventId} {
      // Helper function to check if user is admin
      function isReferralAdmin() {
        return request.auth != null &&
          exists(/databases/$(database)/documents/referralUsers/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/referralUsers/$(request.auth.uid)).data.isAdmin == true;
      }

      // Helper function to check if user has analytics access (Atlas users)
      function hasAnalyticsAccess() {
        return request.auth != null &&
          (exists(/databases/$(database)/documents/atlasUsers/$(request.auth.uid)) ||
           exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
           exists(/databases/$(database)/documents/backoffice_users/$(request.auth.uid)));
      }

      // Read permissions:
      // 1. Referrers can read events for their referral code
      // 2. Admins can read all events
      // 3. Atlas users can read all events for analytics
      allow read: if request.auth != null &&
        (resource.data.referrerId == request.auth.uid ||
         isReferralAdmin() ||
         hasAnalyticsAccess());

      // Create permissions:
      // Anyone can create events (for tracking clicks/downloads)
      allow create: if true;

      // Update/Delete permissions:
      // Only admins can modify events
      allow update, delete: if isReferralAdmin();
    }

    // ============================================
    // STRIPE CONNECT COLLECTIONS
    // Stripe Connect account and payout management
    // ============================================

    // Stripe Connect Accounts Collection
    match /stripe_connect_accounts/{accountId} {
      // Read permissions:
      // 1. Vendors can read their own Stripe account data
      // 2. Admins can read all accounts for support purposes
      allow read: if request.auth != null &&
        (request.auth.uid == resource.data.vendorId ||
         exists(/databases/$(database)/documents/admins/$(request.auth.uid)));

      // Create permissions:
      // Vendors can create their own Stripe account records
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.vendorId;

      // Update permissions:
      // 1. Vendors can update their own account data
      // 2. System can update account status and details
      allow update: if request.auth != null &&
        (request.auth.uid == resource.data.vendorId ||
         exists(/databases/$(database)/documents/admins/$(request.auth.uid)));

      // Delete permissions:
      // Only admins can delete (for cleanup purposes)
      allow delete: if request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Stripe Payouts Collection
    match /stripe_payouts/{payoutId} {
      // Read permissions:
      // 1. Vendors can read their own payout history
      // 2. Admins can read all payouts for support
      allow read: if request.auth != null &&
        (request.auth.uid == resource.data.vendorId ||
         exists(/databases/$(database)/documents/admins/$(request.auth.uid)));

      // Create permissions:
      // System creates payout records (webhook/admin only)
      allow create: if request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));

      // Update permissions:
      // Only system/admins can update payout status
      allow update: if request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));

      // Delete permissions:
      // Payouts are immutable records (no deletion)
      allow delete: if false;
    }

    // Stripe Transactions Collection
    match /stripe_transactions/{transactionId} {
      // Read permissions:
      // 1. Vendors can read their own transaction history
      // 2. Customers can read their own purchase transactions
      // 3. Admins can read all transactions
      allow read: if request.auth != null &&
        (request.auth.uid == resource.data.vendorId ||
         request.auth.uid == resource.data.customerId ||
         exists(/databases/$(database)/documents/admins/$(request.auth.uid)));

      // Create permissions:
      // System creates transaction records
      allow create: if request.auth != null;

      // Update permissions:
      // Only system/admins can update transaction status
      allow update: if request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));

      // Delete permissions:
      // Transactions are immutable records (no deletion)
      allow delete: if false;
    }

    // ============================================
    // PROMOTIONAL EVENTS COLLECTIONS
    // Promotional events management system
    // ============================================

    // Promotional Users Collection
    match /promotionalUsers/{userId} {
      // Helper function to check if user is authenticated promotional user
      function isPromotionalUser() {
        return request.auth != null &&
          exists(/databases/$(database)/documents/promotionalUsers/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/promotionalUsers/$(request.auth.uid)).data.isPromotionalUser == true;
      }

      // Helper function to check if user is Super Admin
      function isPromotionalSuperAdmin() {
        return isPromotionalUser() &&
          get(/databases/$(database)/documents/promotionalUsers/$(request.auth.uid)).data.role == "superadmin";
      }

      // Read permissions:
      // Authenticated users can read their own document
      allow read: if request.auth != null && request.auth.uid == userId;

      // Create permissions:
      // Only Super Admins can create new promotional users
      allow create: if isPromotionalSuperAdmin();

      // Update permissions:
      // Only Super Admins can update promotional users
      allow update: if isPromotionalSuperAdmin();

      // Delete permissions:
      // No deletion allowed (use deactivation instead)
      allow delete: if false;
    }

    // ============================================
    // UNIFIED BACKOFFICE COLLECTIONS
    // Unified back office system with role-based permissions
    // ============================================
    
    // Helper functions for backoffice authentication and authorization
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isBackOfficeUser() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/backoffice_users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/backoffice_users/$(request.auth.uid)).data.isActive == true;
    }
    
    function getBackOfficeUser() {
      return get(/databases/$(database)/documents/backoffice_users/$(request.auth.uid)).data;
    }
    
    function isSuperAdmin() {
      return isBackOfficeUser() && 
        getBackOfficeUser().role == 'superadmin';
    }
    
    function hasPermission(department, level) {
      let user = getBackOfficeUser();
      return user.permissions[department] != null && 
        user.permissions[department][level] == true;
    }
    
    function canAccessDepartment(department) {
      let user = getBackOfficeUser();
      return user.departments.hasAny([department]);
    }
    
    // Back Office Users Collection
    match /backoffice_users/{userId} {
      // Read permissions:
      // 1. Users can read their own document
      // 2. Super Admins can read all users
      allow read: if isBackOfficeUser() && 
        (resource.id == request.auth.uid || isSuperAdmin());
      
      // Create permissions:
      // Only Super Admins can create users (through invitation acceptance)
      allow create: if isSuperAdmin() ||
        (isAuthenticated() && request.auth.uid == userId && 
         request.resource.data.uid == request.auth.uid);
      
      // Update permissions:
      // 1. Super Admins can update any user
      // 2. Users can update their own limited fields (not role, permissions, or isActive)
      allow update: if isSuperAdmin() ||
        (isAuthenticated() && request.auth.uid == userId &&
         request.resource.data.role == resource.data.role &&
         request.resource.data.permissions == resource.data.permissions &&
         request.resource.data.isActive == resource.data.isActive &&
         request.resource.data.departments == resource.data.departments);
      
      // Delete permissions:
      // Only Super Admins can delete users (soft delete preferred)
      allow delete: if isSuperAdmin();
    }
    
    // Back Office Invitations Collection
    match /backoffice_invitations/{invitationId} {
      // Read permissions:
      // 1. Super Admins can read all invitations
      // 2. Users can read invitations sent to their email
      allow read: if isSuperAdmin() ||
        (isAuthenticated() && resource.data.email == request.auth.token.email);
      
      // Create permissions:
      // Only Super Admins can create invitations
      allow create: if isSuperAdmin();
      
      // Update permissions:
      // Only Super Admins can update invitations (status changes)
      allow update: if isSuperAdmin();
      
      // Delete permissions:
      // Only Super Admins can delete invitations
      allow delete: if isSuperAdmin();
    }
    
    // Analytics Data Collections
    match /website_hits/{hitId} {
      // Read permissions:
      // 1. Back office users with analytics read permission
      // 2. Legacy admin and Atlas users (for backward compatibility)
      allow read: if (isBackOfficeUser() && hasPermission('analytics', 'read')) ||
                    (request.auth != null && 
                     (exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
                      exists(/databases/$(database)/documents/atlasUsers/$(request.auth.uid))));
      
      // Create permissions:
      // Anyone can create website hits (including anonymous users for tracking)
      allow create: if true;
      
      // Update permissions:
      // Back office users with analytics write permission
      allow update: if isBackOfficeUser() && hasPermission('analytics', 'write');
      
      // Delete permissions:
      // Back office users with analytics delete permission or legacy admins
      allow delete: if (isBackOfficeUser() && hasPermission('analytics', 'delete')) ||
                      (request.auth != null && 
                       exists(/databases/$(database)/documents/admins/$(request.auth.uid)));
    }
    
    match /sales_data/{dataId} {
      allow read: if isBackOfficeUser() && hasPermission('analytics', 'read');
      allow write: if isBackOfficeUser() && hasPermission('analytics', 'write');
      allow delete: if isBackOfficeUser() && hasPermission('analytics', 'delete');
    }
    
    match /product_analytics/{analyticsId} {
      allow read: if isBackOfficeUser() && hasPermission('analytics', 'read');
      allow write: if isBackOfficeUser() && hasPermission('analytics', 'write');
      allow delete: if isBackOfficeUser() && hasPermission('analytics', 'delete');
    }
    
    match /logistics_data/{dataId} {
      allow read: if isBackOfficeUser() && hasPermission('analytics', 'read');
      allow write: if isBackOfficeUser() && hasPermission('analytics', 'write');
      allow delete: if isBackOfficeUser() && hasPermission('analytics', 'delete');
    }
    
    // Promotional Events Collections
    match /promotional_events/{eventId} {
      // Read permissions:
      // 1. Back office users with promotions read permission
      // 2. Legacy promotional users (for backward compatibility)
      allow read: if (isBackOfficeUser() && hasPermission('promotions', 'read')) ||
                    (request.auth != null && 
                     exists(/databases/$(database)/documents/promotionalUsers/$(request.auth.uid)));
      
      // Create permissions:
      // Back office users with promotions write permission
      allow create: if isBackOfficeUser() && hasPermission('promotions', 'write');
      
      // Update permissions:
      // Back office users with promotions write permission
      allow update: if isBackOfficeUser() && hasPermission('promotions', 'write');
      
      // Delete permissions:
      // Back office users with promotions delete permission
      allow delete: if isBackOfficeUser() && hasPermission('promotions', 'delete');
    }
    
    match /promotional_products/{productId} {
      allow read: if (isBackOfficeUser() && hasPermission('promotions', 'read')) ||
                    (request.auth != null && 
                     exists(/databases/$(database)/documents/promotionalUsers/$(request.auth.uid)));
      allow write: if isBackOfficeUser() && hasPermission('promotions', 'write');
      allow delete: if isBackOfficeUser() && hasPermission('promotions', 'delete');
    }
    
    // Collections CMS Collections
    match /collections/{collectionId} {
      // Read permissions:
      // 1. Back office users with collections read permission
      // 2. Legacy collections users (for backward compatibility)
      // 3. Public read access for frontend
      allow read: if true; // Public read for frontend
      
      // Write permissions:
      // Back office users with collections write permission or legacy users
      allow write: if (isBackOfficeUser() && hasPermission('collections', 'write')) ||
                     (request.auth != null && 
                      exists(/databases/$(database)/documents/collectionsUsers/$(request.auth.uid)));
      
      // Delete permissions:
      // Back office users with collections delete permission
      allow delete: if isBackOfficeUser() && hasPermission('collections', 'delete');
    }
    
    match /featured_collections/{collectionId} {
      allow read: if true; // Public read for frontend
      allow write: if (isBackOfficeUser() && hasPermission('collections', 'write')) ||
                     (request.auth != null && 
                      exists(/databases/$(database)/documents/collectionsUsers/$(request.auth.uid)));
      allow delete: if isBackOfficeUser() && hasPermission('collections', 'delete');
    }
    
    // Marketing Department Collections
    match /marketing_vendors/{vendorId} {
      // Read permissions:
      // 1. Back office users with marketing read permission
      // 2. Legacy marketing users (for backward compatibility)
      allow read: if (isBackOfficeUser() && hasPermission('marketing', 'read')) ||
                    (request.auth != null && 
                     exists(/databases/$(database)/documents/marketing_users/$(request.auth.uid)));
      
      // Write permissions:
      // Back office users with marketing write permission
      allow write: if isBackOfficeUser() && hasPermission('marketing', 'write');
      
      // Delete permissions:
      // Back office users with marketing delete permission
      allow delete: if isBackOfficeUser() && hasPermission('marketing', 'delete');
    }
    
    // Admin Department Collections
    match /system_settings/{settingId} {
      allow read: if isBackOfficeUser() && hasPermission('admin', 'read');
      allow write: if isBackOfficeUser() && hasPermission('admin', 'write');
      allow delete: if isBackOfficeUser() && hasPermission('admin', 'delete');
    }
    
    // Legacy compatibility - update existing collections to work with backoffice
    match /users/{userId} {
      allow read, write: if (request.auth != null && request.auth.uid == userId) ||
                           (isBackOfficeUser() && hasPermission('admin', 'read'));
      
      // Subcollection: /users/{userId}/videos/{videoFile}
      match /videos/{videoFile} {
        allow read, write: if (request.auth != null && request.auth.uid == userId) ||
                             (isBackOfficeUser() && hasPermission('admin', 'read'));
      }
    }
    
    // ============================================
    // WEBSITE HITS COLLECTION
    // Website analytics and visitor tracking
    // ============================================
    match /web_hits/{hitId} {
      // Read permissions:
      // 1. Admins and Atlas users can read all website hits
      // 2. Anyone can query their own visitor_id (needed for duplicate check)
      allow read: if (request.auth != null && 
                      (exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
                       exists(/databases/$(database)/documents/atlasUsers/$(request.auth.uid))))
                   || (request.query != null);  // Allow queries for duplicate checking
      
      // Create permissions:
      // Anyone can create website hits (including anonymous users for tracking)
      allow create: if true;
      
      // Update permissions:
      // No updates allowed (immutable tracking data)
      allow update: if false;
      
      // Delete permissions:
      // Only admins can delete hits (for cleanup)
      allow delete: if request.auth != null && 
                      exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // ============================================
    // VENDOR ANALYTICS COLLECTIONS
    // Vendor analytics dashboard with comprehensive metrics
    // ============================================
    
    // Helper function to check if user is a vendor
    function isVendor() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/tailors/$(request.auth.uid));
    }
    
    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    
    // Vendor Analytics Collection
    match /vendor_analytics/{docId} {
      // Read permissions:
      // 1. Vendors can read their own analytics
      // 2. Admins can read all analytics for support
      allow read: if request.auth != null && 
                     (resource.data.vendorId == request.auth.uid || isAdmin());
      
      // Create/Update permissions:
      // Only system (Cloud Functions) can write analytics data
      allow create, update: if false;
      
      // Delete permissions:
      // Only admins can delete for cleanup
      allow delete: if isAdmin();
    }
    
    // Product Analytics Collection
    match /product_analytics/{docId} {
      // Read permissions:
      // 1. Vendors can read analytics for their products
      // 2. Admins can read all product analytics
      allow read: if request.auth != null && 
                     (resource.data.vendorId == request.auth.uid || isAdmin());
      
      // Create/Update permissions:
      // Only system (Cloud Functions) can write
      allow create, update: if false;
      
      // Delete permissions:
      // Only admins can delete
      allow delete: if isAdmin();
    }
    
    // Vendor Rankings Collection
    match /vendor_rankings/{vendorId} {
      // Read permissions:
      // 1. Vendors can read their own rankings
      // 2. Admins can read all rankings
      allow read: if request.auth != null && 
                     (request.auth.uid == vendorId || isAdmin());
      
      // Create/Update permissions:
      // Only system (Cloud Functions) can write rankings
      allow create, update: if false;
      
      // Delete permissions:
      // Only admins can delete
      allow delete: if isAdmin();
    }
    
    // Customer Segments Collection
    match /customer_segments/{docId} {
      // Read permissions:
      // 1. Vendors can read their own customer segments (anonymized)
      // 2. Admins can read all segments
      allow read: if request.auth != null && 
                     (resource.data.vendorId == request.auth.uid || isAdmin());
      
      // Create/Update permissions:
      // Only system (Cloud Functions) can write
      allow create, update: if false;
      
      // Delete permissions:
      // Only admins can delete
      allow delete: if isAdmin();
    }
    
    // Vendor Payouts Collection
    match /vendor_payouts/{payoutId} {
      // Read permissions:
      // 1. Vendors can read their own payout history
      // 2. Admins can read all payouts
      allow read: if request.auth != null && 
                     (resource.data.vendorId == request.auth.uid || isAdmin());
      
      // Create/Update permissions:
      // Only system (Cloud Functions/webhooks) can write payout records
      allow create, update: if false;
      
      // Delete permissions:
      // Payouts are immutable records (no deletion)
      allow delete: if false;
    }
    
    // Vendor Notifications Collection
    match /vendor_notifications/{notificationId} {
      // Read permissions:
      // 1. Vendors can read their own notifications
      // 2. Admins can read all notifications
      allow read: if request.auth != null && 
                     (resource.data.vendorId == request.auth.uid || isAdmin());
      
      // Create permissions:
      // System can create notifications
      allow create: if request.auth != null;
      
      // Update permissions:
      // 1. Vendors can update their own notifications (mark as read)
      // 2. Admins can update any notification
      allow update: if request.auth != null && 
                       (resource.data.vendorId == request.auth.uid || isAdmin());
      
      // Delete permissions:
      // 1. Vendors can delete their own notifications
      // 2. Admins can delete any notification
      allow delete: if request.auth != null && 
                       (resource.data.vendorId == request.auth.uid || isAdmin());
    }
    
    // Export Audit Logs Collection
    match /export_audit_logs/{logId} {
      // Read permissions:
      // 1. Vendors can read their own export logs
      // 2. Admins can read all export logs
      allow read: if request.auth != null && 
                     (resource.data.vendorId == request.auth.uid || isAdmin());
      
      // Create permissions:
      // System creates export logs
      allow create: if request.auth != null;
      
      // Update/Delete permissions:
      // Export logs are immutable (audit trail)
      allow update, delete: if false;
    }
    
    // ============================================
    // SHOP ACTIVITIES COLLECTION
    // User interaction tracking in shops section
    // Requirements: 21.1, 21.7, 22.1
    // ============================================
    match /shop_activities/{activityId} {
      // Read permissions:
      // 1. Vendors can read activities for their products
      // 2. Admins can read all activities for analytics
      // 3. System can read for processing
      allow read: if request.auth != null && 
                     (resource.data.vendorId == request.auth.uid || isAdmin());
      
      // Create permissions:
      // Anyone can create activity logs (including anonymous users for tracking)
      // This allows tracking of all user interactions in the shops section
      allow create: if true;
      
      // Update permissions:
      // Activities are immutable once created (no updates allowed)
      allow update: if false;
      
      // Delete permissions:
      // 1. Only admins can delete activities (for data retention/cleanup)
      // 2. Automated cleanup after 12 months retention period
      allow delete: if isAdmin();
    }
    
    // ============================================
    // ORDERS COLLECTION
    // Order management for vendors and customers
    // ============================================
    match /orders/{orderId} {
      // Helper function to check if order belongs to vendor
      function isOrderVendor() {
        return request.auth != null && 
               resource.data.vendorId == request.auth.uid;
      }
      
      // Helper function to check if order belongs to customer
      function isOrderCustomer() {
        return request.auth != null && 
               resource.data.customerId == request.auth.uid;
      }

      // Helper function to check if user is authorized marketing user for VVIP operations
      function isVvipAuthorizedUser() {
        return request.auth != null &&
          exists(/databases/$(database)/documents/marketing_users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/marketing_users/$(request.auth.uid)).data.isActive == true;
      }

      // Helper function to check if user can approve/reject VVIP payments
      function canManageVvipPayments() {
        return isVvipAuthorizedUser() &&
          get(/databases/$(database)/documents/marketing_users/$(request.auth.uid)).data.role in ['super_admin', 'bdm'];
      }

      // Helper function to check if VVIP payment fields are being modified
      function isVvipPaymentUpdate() {
        return request.resource.data.diff(resource.data).affectedKeys().hasAny(['payment_status', 'order_status', 'admin_note', 'payment_verified_by', 'payment_verified_at']);
      }

      // Helper function to check if this is a VVIP order
      function isVvipOrder() {
        return resource.data.isVvip == true;
      }
      
      // Read permissions:
      // 1. Vendors can read their own orders
      // 2. Customers can read their own orders
      // 3. Admins can read all orders
      // 4. Authorized marketing users can read VVIP orders
      allow read: if request.auth != null && 
                     (isOrderVendor() || isOrderCustomer() || isAdmin() ||
                      (isVvipAuthorizedUser() && isVvipOrder()));
      
      // Create permissions:
      // 1. Authenticated users can create orders
      // 2. System can create VVIP orders
      allow create: if request.auth != null;
      
      // Update permissions:
      // 1. Vendors can update their orders (status, fulfillment)
      // 2. Customers can update their orders (cancellation, except VVIP payment fields)
      // 3. Admins can update any order
      // 4. Authorized marketing users can update VVIP payment status
      allow update: if request.auth != null && 
                       (isOrderVendor() || 
                        (isOrderCustomer() && !isVvipPaymentUpdate()) || 
                        isAdmin() ||
                        (canManageVvipPayments() && isVvipOrder() && isVvipPaymentUpdate()));
      
      // Delete permissions:
      // 1. Only admins can delete orders (soft delete preferred)
      // 2. Authorized marketing users can delete VVIP orders
      allow delete: if isAdmin() || (canManageVvipPayments() && isVvipOrder());
    }
    
    // ============================================
    // USER ORDERS COLLECTION
    // User-specific orders subcollection
    // ============================================
    match /users_orders/{userId}/user_orders/{orderId} {
      // Helper function to check if order belongs to vendor
      function isOrderVendor() {
        return request.auth != null && 
               resource.data.tailor_id == request.auth.uid;
      }
      
      // Read permissions:
      // 1. Users can read their own orders
      // 2. Vendors can read orders for their products
      // 3. Admins can read all orders
      allow read: if request.auth != null && 
                     (request.auth.uid == userId || isOrderVendor() || isAdmin());
      
      // Create permissions:
      // Users can create their own orders
      allow create: if request.auth != null && request.auth.uid == userId;
      
      // Update permissions:
      // 1. Users can update their own orders
      // 2. Vendors can update orders for their products
      // 3. Admins can update any order
      allow update: if request.auth != null && 
                       (request.auth.uid == userId || isOrderVendor() || isAdmin());
      
      // Delete permissions:
      // Only admins can delete orders
      allow delete: if isAdmin();
    }
    
    // ============================================================
    // DEFAULT RULE (for safety, no open access)
    // ============================================================
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // ============================================
    // AI SHOPPING ASSISTANT COLLECTIONS
    // AI-powered shopping assistant analytics and tracking
    // ============================================
    
    // AI Assistant Sessions Collection
    match /ai_assistant_sessions/{sessionId} {
      // Read permissions:
      // 1. Users can read their own sessions
      // 2. Admins can read all sessions for analytics
      // 3. System can read/write for tracking
      allow read: if request.auth != null && 
                    (resource.data.userId == request.auth.uid ||
                     exists(/databases/$(database)/documents/admins/$(request.auth.uid)));
      
      // Create permissions:
      // Anyone can create sessions (including anonymous users)
      allow create: if true;
      
      // Update permissions:
      // System can update sessions for tracking
      allow update: if true;
      
      // Delete permissions:
      // Users can delete their own sessions, admins can delete any
      allow delete: if request.auth != null && 
                      (resource.data.userId == request.auth.uid ||
                       exists(/databases/$(database)/documents/admins/$(request.auth.uid)));
    }
    
    // AI Assistant Interactions Collection
    match /ai_assistant_interactions/{interactionId} {
      // Read permissions:
      // 1. Users can read their own interactions
      // 2. Admins can read all interactions for analytics
      allow read: if request.auth != null && 
                    (resource.data.userId == request.auth.uid ||
                     exists(/databases/$(database)/documents/admins/$(request.auth.uid)));
      
      // Create permissions:
      // Anyone can create interactions (including anonymous users)
      allow create: if true;
      
      // Update permissions:
      // System can update interactions
      allow update: if true;
      
      // Delete permissions:
      // Only admins can delete interactions
      allow delete: if request.auth != null && 
                      exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    
    // AI Assistant Conversions Collection
    match /ai_assistant_conversions/{conversionId} {
      // Read permissions:
      // 1. Users can read their own conversions
      // 2. Admins can read all conversions for analytics
      allow read: if request.auth != null && 
                    (resource.data.userId == request.auth.uid ||
                     exists(/databases/$(database)/documents/admins/$(request.auth.uid)));
      
      // Create permissions:
      // Anyone can create conversions (including anonymous users)
      allow create: if true;
      
      // Update permissions:
      // System can update conversions
      allow update: if true;
      
      // Delete permissions:
      // Only admins can delete conversions
      allow delete: if request.auth != null && 
                      exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    
    // Chat Sessions Collection (for message history)
    match /chatSessions/{sessionId} {
      // Read permissions:
      // Anyone can read their own session (including anonymous)
      allow read: if true;
      
      // Create permissions:
      // Anyone can create sessions
      allow create: if true;
      
      // Update permissions:
      // Anyone can update their session
      allow update: if true;
      
      // Delete permissions:
      // Anyone can delete their session
      allow delete: if true;
    }
    
    // Chat Messages Collection (for message history)
    match /chatMessages/{messageId} {
      // Read permissions:
      // Anyone can read messages from their session
      allow read: if true;
      
      // Create permissions:
      // Anyone can create messages
      allow create: if true;
      
      // Update permissions:
      // System can update messages
      allow update: if true;
      
      // Delete permissions:
      // Anyone can delete messages from their session
      allow delete: if true;
    }
    
    // User Avatars Collection (for virtual try-on)
    match /userAvatars/{userId} {
      // Read permissions:
      // Users can read their own avatar
      allow read: if request.auth != null && request.auth.uid == userId;
      
      // Create permissions:
      // Users can create their own avatar
      allow create: if request.auth != null && request.auth.uid == userId;
      
      // Update permissions:
      // Users can update their own avatar
      allow update: if request.auth != null && request.auth.uid == userId;
      
      // Delete permissions:
      // Users can delete their own avatar
      allow delete: if request.auth != null && request.auth.uid == userId;
    }
    
    // ============================================
    // BLOG ADMIN COLLECTIONS
    // Blog administration system with role-based permissions
    // ============================================
    
    // Blog Users Collection
    match /blog_users/{userId} {
      // Helper function to check if user is authenticated blog user
      function isBlogUser() {
        return request.auth != null &&
          exists(/databases/$(database)/documents/blog_users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/blog_users/$(request.auth.uid)).data.isActive == true;
      }
      
      // Helper function to check if user is Blog Admin
      function isBlogAdmin() {
        return isBlogUser() &&
          get(/databases/$(database)/documents/blog_users/$(request.auth.uid)).data.role == "admin";
      }
      
      // Read permissions:
      // 1. Users can read their own document
      // 2. Blog admins can read all users
      allow read: if request.auth != null && 
        (request.auth.uid == userId || isBlogAdmin());
      
      // Create permissions:
      // Anyone can register as a blog user (self-registration)
      allow create: if request.auth != null &&
        request.auth.uid == userId &&
        request.resource.data.uid == request.auth.uid;
      
      // Update permissions:
      // 1. Blog admins can update any user
      // 2. Users can update their own limited fields (not role or isActive)
      allow update: if isBlogAdmin() ||
        (request.auth != null && request.auth.uid == userId &&
         request.resource.data.role == resource.data.role &&
         request.resource.data.isActive == resource.data.isActive);
      
      // Delete permissions:
      // Only blog admins can delete users (soft delete preferred)
      allow delete: if isBlogAdmin();
    }
    
    // Blog Invitations Collection
    match /blog_invitations/{invitationId} {
      // Helper function to check if user is authenticated blog user
      function isBlogUser() {
        return request.auth != null &&
          exists(/databases/$(database)/documents/blog_users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/blog_users/$(request.auth.uid)).data.isActive == true;
      }
      
      // Helper function to check if user is Blog Admin
      function isBlogAdmin() {
        return isBlogUser() &&
          get(/databases/$(database)/documents/blog_users/$(request.auth.uid)).data.role == "admin";
      }
      
      // Read permissions:
      // 1. Blog admins can read all invitations
      // 2. Anyone can read their own invitation by email (for validation)
      allow read: if isBlogAdmin() ||
        (request.auth != null && resource.data.email == request.auth.token.email);
      
      // Create permissions:
      // Only blog admins can create invitations
      allow create: if isBlogAdmin();
      
      // Update permissions:
      // Only blog admins can update invitations
      allow update: if isBlogAdmin();
      
      // Delete permissions:
      // Only blog admins can delete invitations
      allow delete: if isBlogAdmin();
    }
    
    // News Collection (used for blog posts)
    match /news/{postId} {
      // Helper function to check if user is authenticated blog user
      function isBlogUser() {
        return request.auth != null &&
          exists(/databases/$(database)/documents/blog_users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/blog_users/$(request.auth.uid)).data.isActive == true;
      }
      
      // Helper function to check if user is Blog Admin
      function isBlogAdmin() {
        return isBlogUser() &&
          get(/databases/$(database)/documents/blog_users/$(request.auth.uid)).data.role == "admin";
      }
      
      // Helper function to check if user is Blog Editor
      function isBlogEditor() {
        return isBlogUser() &&
          get(/databases/$(database)/documents/blog_users/$(request.auth.uid)).data.role in ["admin", "editor"];
      }
      
      // Helper function to check if user can create posts
      function canCreatePost() {
        return isBlogUser() &&
          get(/databases/$(database)/documents/blog_users/$(request.auth.uid)).data.role in ["admin", "editor"];
      }
      
      // Helper function to check if user can edit this post
      function canEditPost() {
        return isBlogAdmin() || 
          isBlogEditor() ||
          (isBlogUser() && (
            resource.data.authorId == request.auth.uid ||
            resource.data.author == get(/databases/$(database)/documents/blog_users/$(request.auth.uid)).data.firstName + " " + get(/databases/$(database)/documents/blog_users/$(request.auth.uid)).data.lastName
          ));
      }
      
      // Helper function to check if user can delete this post
      function canDeletePost() {
        return isBlogAdmin() ||
          (isBlogUser() && (
            resource.data.authorId == request.auth.uid ||
            resource.data.author == get(/databases/$(database)/documents/blog_users/$(request.auth.uid)).data.firstName + " " + get(/databases/$(database)/documents/blog_users/$(request.auth.uid)).data.lastName
          ));
      }
      
      // Read permissions:
      // 1. Published posts can be read by anyone (public)
      // 2. Blog users can read all posts (for admin interface)
      // 3. Authors can read their own unpublished posts
      allow read: if resource.data.published == true ||
        isBlogUser() ||
        (request.auth != null && (
          resource.data.authorId == request.auth.uid ||
          resource.data.author == get(/databases/$(database)/documents/blog_users/$(request.auth.uid)).data.firstName + " " + get(/databases/$(database)/documents/blog_users/$(request.auth.uid)).data.lastName
        ));
      
      // Create permissions:
      // Only editors and admins can create posts
      allow create: if canCreatePost() &&
        (request.resource.data.authorId == request.auth.uid ||
         request.resource.data.author == get(/databases/$(database)/documents/blog_users/$(request.auth.uid)).data.firstName + " " + get(/databases/$(database)/documents/blog_users/$(request.auth.uid)).data.lastName);
      
      // Update permissions:
      // Users can edit posts based on their role and ownership
      allow update: if canEditPost();
      
      // Delete permissions:
      // Users can delete posts based on their role and ownership
      allow delete: if canDeletePost();
    }
    
    // ============================================
    // VIRTUAL FITTING ROOM COLLECTIONS
    // AI-powered virtual fitting room feature
    // ============================================
    
    // Virtual Fittings Collection
    match /virtualFittings/{fittingId} {
      // Read permissions:
      // Users can read their own virtual fittings
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      
      // Create permissions:
      // Authenticated users can create their own virtual fittings
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      
      // Update permissions:
      // Users can update their own virtual fittings
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
      
      // Delete permissions:
      // Users can delete their own virtual fittings
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
    
    // Style Profiles Collection
    match /styleProfiles/{userId} {
      // Read permissions:
      // Users can read their own style profile
      allow read: if request.auth != null && request.auth.uid == userId;
      
      // Create permissions:
      // Users can create their own style profile
      allow create: if request.auth != null && request.auth.uid == userId;
      
      // Update permissions:
      // Users can update their own style profile
      allow update: if request.auth != null && request.auth.uid == userId;
      
      // Delete permissions:
      // Users can delete their own style profile
      allow delete: if request.auth != null && request.auth.uid == userId;
    }
    
    // Outfit Recommendations Collection
    match /outfitRecommendations/{bundleId} {
      // Read permissions:
      // Anyone can read active outfit recommendations
      allow read: if resource.data.active == true || request.auth != null;
      
      // Create permissions:
      // Only authenticated users (system/admin) can create bundles
      allow create: if request.auth != null;
      
      // Update permissions:
      // Only authenticated users (system/admin) can update bundles
      allow update: if request.auth != null;
      
      // Delete permissions:
      // Only authenticated users (system/admin) can delete bundles
      allow delete: if request.auth != null;
    }
    
    // User Generated Content Collection
    match /userGeneratedContent/{contentId} {
      // Read permissions:
      // Anyone can read approved UGC
      allow read: if resource.data.moderationStatus == "approved" || 
                    (request.auth != null && resource.data.userId == request.auth.uid);
      
      // Create permissions:
      // Authenticated users can create their own UGC
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      
      // Update permissions:
      // Users can update their own UGC (before approval)
      // Admins can update any UGC (for moderation)
      allow update: if request.auth != null && 
                      (resource.data.userId == request.auth.uid || 
                       exists(/databases/$(database)/documents/admins/$(request.auth.uid)));
      
      // Delete permissions:
      // Users can delete their own UGC
      // Admins can delete any UGC
      allow delete: if request.auth != null && 
                      (resource.data.userId == request.auth.uid || 
                       exists(/databases/$(database)/documents/admins/$(request.auth.uid)));
    }
    
    // Size Recommendations Collection
    match /sizeRecommendations/{recommendationId} {
      // Read permissions:
      // Users can read their own size recommendations
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      
      // Create permissions:
      // System can create size recommendations for authenticated users
      allow create: if request.auth != null;
      
      // Update permissions:
      // System can update size recommendations (for feedback)
      allow update: if request.auth != null;
      
      // Delete permissions:
      // Users can delete their own size recommendations
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
    
    // Fitting Analytics Collection
    match /fittingAnalytics/{analyticsId} {
      // Read permissions:
      // Only admins and Atlas users can read analytics
      allow read: if request.auth != null && 
                    (exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
                     exists(/databases/$(database)/documents/atlasUsers/$(request.auth.uid)));
      
      // Create permissions:
      // System can create analytics documents
      allow create: if request.auth != null;
      
      // Update permissions:
      // System can update analytics documents
      allow update: if request.auth != null;
      
      // Delete permissions:
      // No deletion allowed (preserve analytics history)
      allow delete: if false;
    }
    
    // ============================================
    // STOREFRONT COLLECTIONS
    // Merchant storefront system with vendor-specific access controls
    // ============================================
    
    // Storefronts Collection - Main storefront configurations
    match /storefronts/{storefrontId} {
      // Read permissions:
      // 1. Vendors can read their own storefront data
      // 2. Public storefronts can be read by anyone
      // 3. Admins can read all storefronts for support
      allow read: if (request.auth != null && resource.data.vendorId == request.auth.uid) ||
                    (resource.data.isPublic == true) ||
                    isAdmin();
      
      // Create permissions:
      // Vendors can create their own storefronts
      allow create: if request.auth != null &&
        request.resource.data.vendorId == request.auth.uid &&
        isVendor();
      
      // Update permissions:
      // 1. Vendors can update their own storefronts
      // 2. Admins can update any storefront for support
      allow update: if (request.auth != null && resource.data.vendorId == request.auth.uid) ||
                      isAdmin();
      
      // Delete permissions:
      // 1. Vendors can delete their own storefronts
      // 2. Admins can delete any storefront
      allow delete: if (request.auth != null && resource.data.vendorId == request.auth.uid) ||
                      isAdmin();
    }
    
    // Storefront Analytics Collection - Event tracking and metrics
    match /storefront_analytics/{analyticsId} {
      // Read permissions:
      // 1. Vendors can read analytics for their own storefronts
      // 2. Admins can read all analytics
      allow read: if (request.auth != null && resource.data.vendorId == request.auth.uid) ||
                    isAdmin();
      
      // Create permissions:
      // System can create analytics events for any storefront
      allow create: if request.auth != null;
      
      // Update permissions:
      // System can update analytics data
      allow update: if request.auth != null;
      
      // Delete permissions:
      // Only admins can delete analytics (for cleanup)
      allow delete: if isAdmin();
    }
    
    // Storefront Templates Collection - Available design templates
    match /storefront_templates/{templateId} {
      // Read permissions:
      // Anyone can read available templates (for template selection)
      allow read: if true;
      
      // Create/Update/Delete permissions:
      // Only admins can manage templates
      allow create, update, delete: if isAdmin();
    }
    
    // Storefront Themes Collection - Custom theme configurations
    match /storefront_themes/{themeId} {
      // Read permissions:
      // 1. Vendors can read their own theme configurations
      // 2. Admins can read all themes
      allow read: if (request.auth != null && resource.data.vendorId == request.auth.uid) ||
                    isAdmin();
      
      // Create permissions:
      // Vendors can create their own theme configurations
      allow create: if request.auth != null &&
        request.resource.data.vendorId == request.auth.uid &&
        isVendor();
      
      // Update permissions:
      // 1. Vendors can update their own themes
      // 2. Admins can update any theme
      allow update: if (request.auth != null && resource.data.vendorId == request.auth.uid) ||
                      isAdmin();
      
      // Delete permissions:
      // 1. Vendors can delete their own themes
      // 2. Admins can delete any theme
      allow delete: if (request.auth != null && resource.data.vendorId == request.auth.uid) ||
                      isAdmin();
    }
    
    // Storefront Pages Collection - Multi-page content storage
    match /storefront_pages/{pageId} {
      // Read permissions:
      // 1. Vendors can read their own storefront pages
      // 2. Public pages can be read by anyone (when storefront is public)
      // 3. Admins can read all pages
      allow read: if (request.auth != null && resource.data.vendorId == request.auth.uid) ||
                    (resource.data.isPublic == true) ||
                    isAdmin();
      
      // Create permissions:
      // Vendors can create pages for their own storefronts
      allow create: if request.auth != null &&
        request.resource.data.vendorId == request.auth.uid &&
        isVendor();
      
      // Update permissions:
      // 1. Vendors can update their own pages
      // 2. Admins can update any page
      allow update: if (request.auth != null && resource.data.vendorId == request.auth.uid) ||
                      isAdmin();
      
      // Delete permissions:
      // 1. Vendors can delete their own pages
      // 2. Admins can delete any page
      allow delete: if (request.auth != null && resource.data.vendorId == request.auth.uid) ||
                      isAdmin();
    }

    // ============================================
    // PRODUCTS COLLECTION
    // Product management for vendors
    // ============================================
    
    // Products Collection
    match /products/{productId} {
      // Read permissions:
      // 1. Anyone can read active products (for public storefront display)
      // 2. Vendors can read their own products (including inactive ones)
      // 3. Admins can read all products
      allow read: if (resource.data.status == 'active') ||
                    (request.auth != null && resource.data.vendor_id == request.auth.uid) ||
                    isAdmin();
      
      // Create permissions:
      // Vendors can create their own products
      allow create: if request.auth != null &&
        request.resource.data.vendor_id == request.auth.uid &&
        isVendor();
      
      // Update permissions:
      // 1. Vendors can update their own products
      // 2. Admins can update any product
      allow update: if (request.auth != null && resource.data.vendor_id == request.auth.uid) ||
                      isAdmin();
      
      // Delete permissions:
      // 1. Vendors can delete their own products
      // 2. Admins can delete any product
      allow delete: if (request.auth != null && resource.data.vendor_id == request.auth.uid) ||
                      isAdmin();
    }

    // ============================================
    // BOGO (BUY ONE GET ONE FREE) COLLECTIONS
    // BOGO promotion system with product mappings
    // ============================================
    
    // BOGO Mappings Collection
    match /bogo_mappings/{mappingId} {
      // Helper function to check if user is promotional admin
      function isPromotionalAdmin() {
        return request.auth != null &&
          ((exists(/databases/$(database)/documents/admins/$(request.auth.uid))) ||
           (exists(/databases/$(database)/documents/promotionalUsers/$(request.auth.uid)) &&
            get(/databases/$(database)/documents/promotionalUsers/$(request.auth.uid)).data.role in ["admin", "superadmin"]) ||
           (exists(/databases/$(database)/documents/atlasUsers/$(request.auth.uid)) &&
            get(/databases/$(database)/documents/atlasUsers/$(request.auth.uid)).data.role in ["superadmin", "founder", "brand_lead"]));
      }
      
      // Read permissions:
      // 1. Public read access for customer cart operations and product display
      // 2. This allows the frontend to check for active BOGO mappings
      allow read: if true;
      
      // Create permissions:
      // Only promotional admins can create BOGO mappings
      allow create: if isPromotionalAdmin() &&
        request.resource.data.createdBy == request.auth.uid;
      
      // Update permissions:
      // Only promotional admins can update BOGO mappings
      allow update: if isPromotionalAdmin();
      
      // Delete permissions:
      // Only promotional admins can delete BOGO mappings
      allow delete: if isPromotionalAdmin();
    }
    
    // BOGO Analytics Collection
    match /bogo_analytics/{analyticsId} {
      // Helper function to check if user is promotional admin
      function isPromotionalAdmin() {
        return request.auth != null &&
          ((exists(/databases/$(database)/documents/admins/$(request.auth.uid))) ||
           (exists(/databases/$(database)/documents/promotionalUsers/$(request.auth.uid)) &&
            get(/databases/$(database)/documents/promotionalUsers/$(request.auth.uid)).data.role in ["admin", "superadmin"]) ||
           (exists(/databases/$(database)/documents/atlasUsers/$(request.auth.uid)) &&
            get(/databases/$(database)/documents/atlasUsers/$(request.auth.uid)).data.role in ["superadmin", "founder", "brand_lead"]));
      }
      
      // Read permissions:
      // Only promotional admins can read analytics
      allow read: if isPromotionalAdmin();
      
      // Create/Update permissions:
      // Only system (Cloud Functions) and promotional admins can write analytics
      allow create, update: if isPromotionalAdmin();
      
      // Delete permissions:
      // Only promotional admins can delete analytics (for cleanup)
      allow delete: if isPromotionalAdmin();
    }

    // BOGO Analytics Events Collection (Public Tracking)
    match /bogo_analytics_events/{eventId} {
      // Helper function to check if user is promotional admin
      function isPromotionalAdmin() {
        return request.auth != null &&
          ((exists(/databases/$(database)/documents/admins/$(request.auth.uid))) ||
           (exists(/databases/$(database)/documents/promotionalUsers/$(request.auth.uid)) &&
            get(/databases/$(database)/documents/promotionalUsers/$(request.auth.uid)).data.role in ["admin", "superadmin"]) ||
           (exists(/databases/$(database)/documents/atlasUsers/$(request.auth.uid)) &&
            get(/databases/$(database)/documents/atlasUsers/$(request.auth.uid)).data.role in ["superadmin", "founder", "brand_lead"]));
      }

      // Create permissions:
      // Allow public creation for analytics tracking
      allow create: if true;

      // Read permissions:
      // Only admins can view data
      allow read: if isPromotionalAdmin();

      // Update/Delete permissions:
      // Immutable data
      allow update, delete: if false;
    }
    
    // BOGO Audit Logs Collection
    match /bogo_audit_logs/{logId} {
      // Helper function to check if user is promotional admin
      function isPromotionalAdmin() {
        return request.auth != null &&
          ((exists(/databases/$(database)/documents/admins/$(request.auth.uid))) ||
           (exists(/databases/$(database)/documents/promotionalUsers/$(request.auth.uid)) &&
            get(/databases/$(database)/documents/promotionalUsers/$(request.auth.uid)).data.role in ["admin", "superadmin"]) ||
           (exists(/databases/$(database)/documents/atlasUsers/$(request.auth.uid)) &&
            get(/databases/$(database)/documents/atlasUsers/$(request.auth.uid)).data.role in ["superadmin", "founder", "brand_lead"]));
      }
      
      // Read permissions:
      // Only promotional admins can read audit logs
      allow read: if isPromotionalAdmin();
      
      // Create permissions:
      // System and promotional admins can create audit logs
      allow create: if request.auth != null;
      
      // Update/Delete permissions:
      // Audit logs are immutable (no updates or deletions)
      allow update, delete: if false;
    }

    // ============================================
    // AI SHOPPING ASSISTANT COLLECTIONS
    // Chat sessions and message history
    // ============================================
    
    // Chat Sessions Collection
    match /chatSessions/{sessionId} {
      // Read permissions:
      // 1. Users can read their own sessions
      // 2. Anonymous users can read sessions they created (by sessionId)
      allow read: if (request.auth != null && resource.data.userId == request.auth.uid) ||
                    (request.auth == null);
      
      // Create permissions:
      // Anyone can create a chat session (authenticated or anonymous)
      allow create: if true;
      
      // Update permissions:
      // 1. Users can update their own sessions
      // 2. Anonymous users can update sessions (for context updates)
      allow update: if (request.auth != null && resource.data.userId == request.auth.uid) ||
                      (request.auth == null);
      
      // Delete permissions:
      // 1. Users can delete their own sessions
      // 2. Anonymous users can delete sessions
      allow delete: if (request.auth != null && resource.data.userId == request.auth.uid) ||
                      (request.auth == null);
    }
    
    // Chat Messages Collection
    match /chatMessages/{messageId} {
      // Read permissions:
      // Anyone can read messages from their session
      allow read: if true;
      
      // Create permissions:
      // Anyone can create messages (authenticated or anonymous)
      allow create: if true;
      
      // Update permissions:
      // Messages are immutable (no updates allowed)
      allow update: if false;
      
      // Delete permissions:
      // Messages can be deleted when session is deleted
      allow delete: if true;
    }

    // ============================================
    // COLLECTIONS ANALYTICS
    // Analytics tracking for product collections
    // ============================================
    
    // Collection Analytics Events Collection
    match /collection_analytics_events/{eventId} {
      // Helper function to check if user is collections admin
      function isCollectionsAdmin() {
        return request.auth != null &&
          exists(/databases/$(database)/documents/collectionsUsers/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/collectionsUsers/$(request.auth.uid)).data.isCollectionsUser == true;
      }
      
      // Read permissions:
      // 1. Collections admins can read all analytics events
      // 2. Atlas admins can read all analytics events
      allow read: if isCollectionsAdmin() ||
                    (request.auth != null && 
                     exists(/databases/$(database)/documents/atlasUsers/$(request.auth.uid)) &&
                     get(/databases/$(database)/documents/atlasUsers/$(request.auth.uid)).data.isAtlasUser == true);
      
      // Create permissions:
      // Anyone can create analytics events (for tracking)
      allow create: if true;
      
      // Update permissions:
      // Analytics events are immutable (no updates allowed)
      allow update: if false;
      
      // Delete permissions:
      // Only collections admins can delete events (for cleanup)
      allow delete: if isCollectionsAdmin();
    }
    
    // Collection Analytics Counters Collection
    match /collection_analytics_counters/{collectionId} {
      // Helper function to check if user is collections admin
      function isCollectionsAdmin() {
        return request.auth != null &&
          exists(/databases/$(database)/documents/collectionsUsers/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/collectionsUsers/$(request.auth.uid)).data.isCollectionsUser == true;
      }
      
      // Read permissions:
      // 1. Collections admins can read all counters
      // 2. Atlas admins can read all counters
      allow read: if isCollectionsAdmin() ||
                    (request.auth != null && 
                     exists(/databases/$(database)/documents/atlasUsers/$(request.auth.uid)) &&
                     get(/databases/$(database)/documents/atlasUsers/$(request.auth.uid)).data.isAtlasUser == true);
      
      // Create permissions:
      // System can create counters
      allow create: if true;
      
      // Update permissions:
      // System can update counters (for incrementing)
      allow update: if true;
      
      // Delete permissions:
      // Only collections admins can delete counters
      allow delete: if isCollectionsAdmin();
    }

    // ============================================
    // AGENT CHAT SYSTEM
    // Customer support chat system with agent handoff
    // ============================================
    
    // Agent Chat Sessions Collection
    match /agent_chat_sessions/{sessionId} {
      // Helper function to check if user is Atlas admin
      function isAtlasAdmin() {
        return request.auth != null &&
          exists(/databases/$(database)/documents/atlasUsers/$(request.auth.uid));
      }
      
      // Helper function to check if user is marketing admin
      function isMarketingAdmin() {
        return request.auth != null &&
          exists(/databases/$(database)/documents/marketing_users/$(request.auth.uid));
      }
      
      // Read permissions:
      // 1. Atlas admins can read all sessions
      // 2. Marketing admins can read all sessions
      // 3. Assigned agents can read their sessions
      // 4. Session owner (userId) can read their own session
      allow read: if isAtlasAdmin() || 
                    isMarketingAdmin() ||
                    (request.auth != null && request.auth.uid == resource.data.assignedAgentId) ||
                    (request.auth != null && request.auth.uid == resource.data.userId) ||
                    resource.data.userId.matches('guest-.*');
      
      // Create permissions:
      // Anyone can create chat sessions (for customer support)
      allow create: if true;
      
      // Update permissions:
      // 1. Atlas admins can update sessions
      // 2. Marketing admins can update sessions
      // 3. Assigned agents can update their sessions
      allow update: if isAtlasAdmin() || 
                      isMarketingAdmin() ||
                      (request.auth != null && request.auth.uid == resource.data.assignedAgentId);
      
      // Delete permissions:
      // Only Atlas admins can delete sessions
      allow delete: if isAtlasAdmin();
    }
    
    // Agent Chat Messages Collection
    match /agent_chat_messages/{messageId} {
      // Helper function to check if user is Atlas admin
      function isAtlasAdmin() {
        return request.auth != null &&
          exists(/databases/$(database)/documents/atlasUsers/$(request.auth.uid));
      }
      
      // Helper function to check if user is marketing admin
      function isMarketingAdmin() {
        return request.auth != null &&
          exists(/databases/$(database)/documents/marketing_users/$(request.auth.uid));
      }
      
      // Read permissions:
      // 1. Atlas admins can read all messages
      // 2. Marketing admins can read all messages
      // 3. Message authors can read their messages
      // 4. Anyone can read messages (consultation messages should be accessible to customers)
      allow read: if true;
      
      // Create permissions:
      // 1. Anyone can create messages (for customer support)
      // 2. Atlas admins can create messages
      // 3. Marketing admins can create messages
      allow create: if true || isAtlasAdmin() || isMarketingAdmin();
      
      // Update permissions:
      // Messages are immutable (no updates allowed)
      allow update: if false;
      
      // Delete permissions:
      // Only Atlas admins can delete messages
      allow delete: if isAtlasAdmin();
    }
    
    // Agent Chat Typing Indicators Collection
    match /agent_chat_typing/{typingId} {
      // Helper function to check if user is Atlas admin
      function isAtlasAdmin() {
        return request.auth != null &&
          exists(/databases/$(database)/documents/atlasUsers/$(request.auth.uid));
      }
      
      // Helper function to check if user is marketing admin
      function isMarketingAdmin() {
        return request.auth != null &&
          exists(/databases/$(database)/documents/marketing_users/$(request.auth.uid));
      }
      
      // Read permissions:
      // 1. Atlas admins can read typing indicators
      // 2. Marketing admins can read typing indicators
      // 3. Users can read typing indicators for their sessions
      allow read: if isAtlasAdmin() || isMarketingAdmin() || true;
      
      // Create permissions:
      // Anyone can create typing indicators
      allow create: if true;
      
      // Update permissions:
      // Anyone can update typing indicators (for real-time updates)
      allow update: if true;
      
      // Delete permissions:
      // Anyone can delete typing indicators (for cleanup)
      allow delete: if true;
    }
    
    // User Credentials Collection (for agent chat analytics)
    match /user_credentials/{userId} {
      // Helper function to check if user is Atlas admin
      function isAtlasAdmin() {
        return request.auth != null &&
          exists(/databases/$(database)/documents/atlasUsers/$(request.auth.uid));
      }
      
      // Helper function to check if user is marketing admin
      function isMarketingAdmin() {
        return request.auth != null &&
          exists(/databases/$(database)/documents/marketing_users/$(request.auth.uid));
      }
      
      // Read permissions:
      // 1. Atlas admins can read user credentials
      // 2. Marketing admins can read user credentials
      // 3. Users can read their own credentials
      allow read: if isAtlasAdmin() || 
                    isMarketingAdmin() ||
                    (request.auth != null && request.auth.uid == userId);
      
      // Create permissions:
      // Anyone can create user credentials (for chat handoff)
      allow create: if true;
      
      // Update permissions:
      // 1. Atlas admins can update credentials
      // 2. Marketing admins can update credentials
      // 3. Users can update their own credentials
      allow update: if isAtlasAdmin() || 
                      isMarketingAdmin() ||
                      (request.auth != null && request.auth.uid == userId);
      
      // Delete permissions:
      // Only Atlas admins can delete credentials
      allow delete: if isAtlasAdmin();
    }

    // ============================================
    // VENDOR WAITLIST MANAGEMENT COLLECTIONS
    // Collection waitlists and subscription management
    // ============================================

    // Collection Waitlists - Vendor-created product collections
    match /collection_waitlists/{waitlistId} {
      // Helper function to check if user is vendor who owns this collection
      function isCollectionOwner() {
        return request.auth != null && 
          resource.data.vendorId == request.auth.uid;
      }
      
      // Helper function to check if user is admin with waitlist access
      function isWaitlistAdmin() {
        return request.auth != null &&
          (exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
           exists(/databases/$(database)/documents/atlasUsers/$(request.auth.uid)));
      }
      
      // Read permissions:
      // 1. Vendors can read their own collections
      // 2. Admins can read all collections
      // 3. Public can read published collections
      allow read: if isCollectionOwner() || 
                    isWaitlistAdmin() ||
                    (resource.data.status == 'published');
      
      // Create permissions:
      // Authenticated vendors can create collections
      allow create: if request.auth != null &&
        request.resource.data.vendorId == request.auth.uid;
      
      // Update permissions:
      // 1. Vendors can update their own collections
      // 2. Admins can update any collection
      // 3. Cannot edit minSubscribers after publishing (business rule)
      allow update: if (isCollectionOwner() || isWaitlistAdmin()) &&
        (resource.data.status == 'draft' || 
         request.resource.data.minSubscribers == resource.data.minSubscribers);
      
      // Delete permissions:
      // 1. Vendors can delete their own draft collections
      // 2. Admins can delete any collection
      allow delete: if (isCollectionOwner() && resource.data.status == 'draft') ||
                      isWaitlistAdmin();
    }

    // Waitlist Subscriptions - User subscriptions to collections
    match /waitlist_subscriptions/{subscriptionId} {
      // Helper function to check if user owns this subscription
      function isSubscriptionOwner() {
        return request.auth != null && 
          resource.data.userId == request.auth.uid;
      }
      
      // Helper function to check if user is vendor of the collection
      function isCollectionVendor() {
        return request.auth != null &&
          exists(/databases/$(database)/documents/collection_waitlists/$(resource.data.collectionId)) &&
          get(/databases/$(database)/documents/collection_waitlists/$(resource.data.collectionId)).data.vendorId == request.auth.uid;
      }
      
      // Helper function to check if user is admin
      function isWaitlistAdmin() {
        return request.auth != null &&
          (exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
           exists(/databases/$(database)/documents/atlasUsers/$(request.auth.uid)));
      }
      
      // Read permissions:
      // 1. Subscription owners can read their own subscriptions
      // 2. Collection vendors can read subscriptions to their collections
      // 3. Admins can read all subscriptions
      allow read: if isSubscriptionOwner() || 
                    isCollectionVendor() ||
                    isWaitlistAdmin();
      
      // Create permissions:
      // Anyone can create subscriptions (including anonymous for public signup)
      allow create: if true;
      
      // Update permissions:
      // 1. Subscription owners can update their preferences
      // 2. Collection vendors can update subscription status
      // 3. Admins can update any subscription
      allow update: if isSubscriptionOwner() || 
                      isCollectionVendor() ||
                      isWaitlistAdmin();
      
      // Delete permissions:
      // 1. Subscription owners can delete their subscriptions (unsubscribe)
      // 2. Admins can delete any subscription
      allow delete: if isSubscriptionOwner() || isWaitlistAdmin();
    }

    // Collection Analytics - Analytics data for collections
    match /collection_analytics/{analyticsId} {
      // Helper function to check if user is vendor of the collection
      function isCollectionVendor() {
        return request.auth != null &&
          resource.data.vendorId == request.auth.uid;
      }
      
      // Helper function to check if user has analytics access
      function hasAnalyticsAccess() {
        return request.auth != null &&
          (exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
           exists(/databases/$(database)/documents/atlasUsers/$(request.auth.uid)) ||
           exists(/databases/$(database)/documents/backoffice_users/$(request.auth.uid)));
      }
      
      // Read permissions:
      // 1. Collection vendors can read analytics for their collections
      // 2. Users with analytics access can read all analytics
      allow read: if isCollectionVendor() || hasAnalyticsAccess();
      
      // Write permissions:
      // Only system/admins can write analytics data
      allow write: if hasAnalyticsAccess();
      
      // Delete permissions:
      // Only admins can delete analytics data
      allow delete: if hasAnalyticsAccess();
    }

    // Waitlist Notification Templates - Email templates for notifications
    match /waitlist_notification_templates/{templateId} {
      // Helper function to check if user is admin
      function isWaitlistAdmin() {
        return request.auth != null &&
          (exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
           exists(/databases/$(database)/documents/atlasUsers/$(request.auth.uid)));
      }
      
      // Read permissions:
      // 1. Admins can read all templates
      // 2. Vendors can read active templates (for preview)
      allow read: if isWaitlistAdmin() || 
                    (request.auth != null && resource.data.isActive == true);
      
      // Write permissions:
      // Only admins can create/update templates
      allow write: if isWaitlistAdmin();
      
      // Delete permissions:
      // Only admins can delete templates
      allow delete: if isWaitlistAdmin();
    }

    // ============================================
    // COUPONS COLLECTION
    // Email-tied coupon management system
    // ============================================
    match /coupons/{couponId} {
      // Helper function to check if user is Atlas admin
      function isAtlasAdmin() {
        return request.auth != null &&
          exists(/databases/$(database)/documents/atlasUsers/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/atlasUsers/$(request.auth.uid)).data.isAtlasUser == true;
      }
      
      // Read permissions:
      // Only Atlas admins can read coupons
      // No public access to prevent coupon code discovery
      allow read: if isAtlasAdmin();
      
      // Create permissions:
      // Only Atlas admins can create coupons
      allow create: if isAtlasAdmin() &&
        request.resource.data.createdBy == request.auth.uid &&
        request.resource.data.couponCode is string &&
        request.resource.data.assignedEmail is string &&
        request.resource.data.discountType in ['PERCENTAGE', 'FIXED'] &&
        request.resource.data.discountValue is number &&
        request.resource.data.status in ['ACTIVE', 'DISABLED'];
      
      // Update permissions:
      // Only Atlas admins can update coupons
      // Cannot change couponCode, discountType, discountValue, or assignedEmail after creation
      allow update: if isAtlasAdmin() &&
        request.resource.data.couponCode == resource.data.couponCode &&
        request.resource.data.discountType == resource.data.discountType &&
        request.resource.data.discountValue == resource.data.discountValue &&
        request.resource.data.assignedEmail == resource.data.assignedEmail &&
        request.resource.data.createdBy == resource.data.createdBy;
      
      // Delete permissions:
      // Only Atlas admins can delete coupons
      allow delete: if isAtlasAdmin();
    }

    // ============================================
    // AGENTS COLLECTION
    // Agent dashboard user management
    // ============================================
    match /agents/{agentId} {
      // Helper function to check if user is authenticated agent
      function isAgent() {
        return request.auth != null 
          && exists(/databases/$(database)/documents/agents/$(request.auth.uid));
      }
      
      // Helper function to check if user is admin
      function isAdmin() {
        return request.auth != null 
          && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
      }
      
      // Read permissions:
      // 1. Authenticated users can read their own agent document (needed for login validation)
      // 2. Admins can read all agent documents
      allow read: if (request.auth != null && request.auth.uid == agentId)
        || isAdmin();
      
      // Create permissions:
      // Only admins can create new agent documents
      allow create: if isAdmin();
      
      // Update permissions:
      // 1. Admins can update any agent document
      // 2. Agents can update their own document (limited fields - cannot change role or permissions)
      allow update: if isAdmin()
        || (request.auth != null 
          && request.auth.uid == agentId
          && request.resource.data.role == resource.data.role
          && request.resource.data.permissions == resource.data.permissions
          && request.resource.data.uid == resource.data.uid);
      
      // Delete permissions:
      // Only admins can delete agent documents
      allow delete: if isAdmin();
    }
  }
}