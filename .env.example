# Email Configuration
MICROSOFT_EMAIL=
MICROSOFT_PASSWORD=
EMAIL_USER=
EMAIL_PASS=

# SMTP Configuration for Agent Chat Notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@stitchesafrica.com

# Flutterwave Payment Configuration
FLW_PUBLIC_KEY=
FLW_SECRET_KEY=
FLW_ENCRYPTION_KEY=
FLW_SECRET_HASH=

# Firebase Configuration
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_SERVICE_ACCOUNT_KEY_BASE64=

# Firebase Public Configuration
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Collections Configuration
# Set to 'true' to use staging collections (staging_*)
# Set to 'false' or remove to use production collections
NEXT_PUBLIC_USE_STAGING_COLLECTIONS=true
USE_STAGING_COLLECTIONS=true

# Image Services
NEXT_PUBLIC_REMOVEBG_API_KEY=
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=

# Payment Configuration
NEXT_PUBLIC_FLUTTERWAVE_PUBLIC_KEY=
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=

# Stripe Configuration
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# JWT Secret
JWT_SECRET=

# Base URL
NEXT_PUBLIC_BASE_URL=

# DHL API Configuration
NEXT_PUBLIC_DHL_API_BASE=

# OpenAI Configuration for AI Shopping Assistant
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here
# Model to use: gpt-4-turbo-preview, gpt-4, or gpt-3.5-turbo
OPENAI_MODEL=gpt-4-turbo-preview
# Maximum tokens for AI responses (recommended: 1000)
OPENAI_MAX_TOKENS=1000
# Temperature for response creativity (0.0-1.0, recommended: 0.7)
OPENAI_TEMPERATURE=0.7

# SureGifts API Configuration
# Get credentials from: https://merchant.suregifts.com.ng
SUREGIFTS_API_URL=https://api.suregifts.com.ng/v1
SUREGIFTS_API_KEY=your_suregifts_api_key_here
SUREGIFTS_SECRET_KEY=your_suregifts_secret_key_here
# Note: Ensure your server IP is whitelisted in SureGifts dashboard
